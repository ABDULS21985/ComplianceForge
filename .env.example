# ── Application ───────────────────────────────────────────────
APP_NAME=ComplianceForge
APP_ENV=development
APP_PORT=8080
APP_GRPC_PORT=9090
APP_WORKER_ENABLED=true

# ── PostgreSQL ───────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=complianceforge
DB_PASSWORD=changeme
DB_NAME=complianceforge
DB_SSL_MODE=disable
DB_MAX_CONNS=25
DB_MIN_CONNS=5

# ── Redis ────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ── RabbitMQ ─────────────────────────────────────────────────
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET=replace-with-a-strong-secret
JWT_ISSUER=complianceforge
JWT_EXPIRY_HOURS=24

# ── OAuth / SSO ──────────────────────────────────────────────
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_REDIRECT_URL=http://localhost:8080/auth/callback

# ── SMTP / Email ─────────────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@complianceforge.local

# ── Storage ──────────────────────────────────────────────────
STORAGE_TYPE=local
STORAGE_PATH=./storage
S3_BUCKET=
S3_REGION=eu-west-2

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=debug
LOG_FORMAT=json

# ── HTTP ─────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000
RATE_LIMIT_RPS=100
